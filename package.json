{
  "name": "voice-platform",
  "private": true,
  "workspaces": [
    "apps/*",
    "services/*",
    "packages/*",
    "workers/*"
  ],
  "scripts": {
    "build": "turbo run build",
    "dev": "turbo run dev",
    "lint": "turbo run lint",
    "format": "prettier --write \"**/*.{ts,tsx,md}\""
  },
  "devDependencies": {
    "turbo": "^1.10.12",
    "typescript": "^5.1.6",
    "prettier": "^3.0.0"
  }
}
